	clean-bitmapLTLIBRARIES clean-explorerLTLIBRARIES \
	clean-generic clean-guiLTLIBRARIES clean-handlerLTLIBRARIES \
	clean-libtool clean-readerLTLIBRARIES clean-threadLTLIBRARIES \
	clean-windowLTLIBRARIES mostlyclean-am

