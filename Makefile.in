	@$(NORMAL_UNINSTALL)
	@list='$(bitmap_LTLIBRARIES)'; test -n "$(bitmapdir)" || list=; \
	for p in $$list; do \
	  $(am__strip_dir) \
	  echo " $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=uninstall rm -f '$(DESTDIR)$(bitmapdir)/$$f'"; \
	  $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=uninstall rm -f "$(DESTDIR)$(bitmapdir)/$$f"; \
	done

clean-bitmapLTLIBRARIES:
	-test -z "$(bitmap_LTLIBRARIES)" || rm -f $(bitmap_LTLIBRARIES)
	@list='$(bitmap_LTLIBRARIES)'; \
	locs=`for p in $$list; do echo $$p; done | \
	      sed 's|^[^/]*$$|.|; s|/[^/]*$$||; s|$$|/so_locations|' | \
	      sort -u`; \
	test -z "$$locs" || { \
	  echo rm -f $${locs}; \
	  rm -f $${locs}; \
	}

